# --- AI / Anthropic Claude ---
EXPO_PUBLIC_ANTHROPIC_API_KEY=
EXPO_PUBLIC_ANTHROPIC_MODEL=claude-haiku-4-5

# --- Enterprise MCP gateways for Claude Code ---
# Project-scoped MCP definitions live in .mcp.json
# Point these URLs to your approved Jira/Figma MCP gateways or local proxies.
FUSE_MCP_JIRA_URL=http://127.0.0.1:8791/mcp
FUSE_MCP_JIRA_BEARER=
FUSE_MCP_JIRA_WORKSPACE=fuse

FUSE_MCP_FIGMA_URL=http://127.0.0.1:8792/mcp
FUSE_MCP_FIGMA_BEARER=
FUSE_MCP_FIGMA_TEAM=design

# Copy this file to .env and fill the values. Do NOT commit .env
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# --- AI / OpenRouter (public Expo vars) ---
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_BASE_URL=https://openrouter.ai/api/v1
EXPO_PUBLIC_OPENAI_MODEL=openai/gpt-4o-mini
EXPO_PUBLIC_OPENAI_FALLBACK_ON_429=true
EXPO_PUBLIC_APP_URL=http://localhost
EXPO_PUBLIC_APP_NAME=Fuse Dev

# Optional image/tts models
EXPO_PUBLIC_OPENAI_IMAGE_MODEL=
EXPO_PUBLIC_OPENAI_TTS_MODEL=

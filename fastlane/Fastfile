# Fastlane Configuration for FUSE

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

# ═══════════════════════════════════════════════════════════════════
# iOS Lanes
# ═══════════════════════════════════════════════════════════════════

platform :ios do
  desc "🏗️ [SIMULATED] Build iOS app for development"
  lane :build_development_simulated do
    puts ""
    puts "════════════════════════════════════════════════════════════"
    puts "🍎 [SIMULATED] Building iOS Development Build"
    puts "════════════════════════════════════════════════════════════"

{
  "mcpServers": {
    "jira": {
      "type": "http",
      "url": "${FUSE_MCP_JIRA_URL:-http://127.0.0.1:8791/mcp}",
      "headers": {
        "Authorization": "Bearer ${FUSE_MCP_JIRA_BEARER:-}",
        "X-FUSE-Workspace": "${FUSE_MCP_JIRA_WORKSPACE:-fuse}"
      }
    },
    "figma": {
      "type": "http",
      "url": "${FUSE_MCP_FIGMA_URL:-http://127.0.0.1:8792/mcp}",
      "headers": {
        "Authorization": "Bearer ${FUSE_MCP_FIGMA_BEARER:-}",
        "X-FUSE-Team": "${FUSE_MCP_FIGMA_TEAM:-design}"
      }
    }
  }
}

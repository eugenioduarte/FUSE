#!/usr/bin/env sh

# ─────────────────────────────────────────────────────────────
# PRE-PUSH HOOK
# Runs full quality gate before any push:
#   1. TypeScript check
#   2. ESLint       (skipped if not configured)
#   3. Tests        (skipped if not configured)
# ─────────────────────────────────────────────────────────────

echo "🔍 TypeScript check..."
yarn typecheck || { echo "❌ TypeScript errors found. Push blocked."; exit 1; }

if [ -f "node_modules/.bin/eslint" ]; then
  echo "🔍 ESLint..."
  yarn lint || { echo "❌ Lint errors found. Push blocked."; exit 1; }
else
  echo "⚠️  ESLint not installed — skipping"
fi

if [ -f "node_modules/.bin/jest" ]; then
  echo "🧪 Tests + coverage..."
  yarn test || { echo "❌ Tests failed. Push blocked."; exit 1; }
else
  echo "⚠️  Jest not installed — skipping"
fi

# Token usage tracking
if [ -f ".claude/observability/update-token-totals.sh" ]; then
  echo ""
  .claude/observability/update-token-totals.sh
fi

# Documentation drift check
if [ -f ".claude/scripts/update-readme.sh" ]; then
  bash .claude/scripts/update-readme.sh
fi

echo "✅ All checks passed. Pushing..."

{
  "name": "autoauction",
  "main": "expo/AppEntry",
  "version": "1.0.0",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ]
  },
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start -c",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "yarn lint && yarn format:check",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "ci:test": "jest --ci --coverage --maxWorkers=2",
    "clean:caches": "watchman watch-del-all || true && rm -rf node_modules && yarn cache clean --all && rm -rf $TMPDIR/metro-* $TMPDIR/haste-map-* && rm -rf ios/build ios/DerivedData android/build android/app/build && yarn install",
    "e2e": "echo \"Starting Maestro...\" && yarn dlx maestro test .maestro/login_test.yaml --target simulator --verbose",
    "e2e:open": "echo \"Opening Maestro Studio...\" && yarn dlx maestro studio",
    "prepare": "husky install"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.5.7",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.25",
    "@react-navigation/stack": "^7.4.10",
    "@shopify/react-native-skia": "^2.3.7",
    "@tanstack/react-query": "^5.90.5",
    "@testing-library/react-hooks": "^8.0.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "~54.0.0",
    "expo-av": "~16.0.7",
    "expo-blur": "~15.0.7",
    "expo-constants": "~18.0.10",
    "expo-device": "^8.0.9",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.17",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linking": "~8.0.8",
    "expo-localization": "~17.0.7",
    "expo-notifications": "^0.32.12",
    "expo-print": "~15.0.7",
    "expo-secure-store": "~15.0.7",
